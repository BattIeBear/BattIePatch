<?xml version="1.0" encoding="utf-8" ?>
<Patch>

	<Operation Class="PatchOperationReplace">
		<xpath>/Defs/ThingDef[defName="SecurityDoor"]/thingClass</xpath>
		<value>
			<thingClass>BattIePatch_Lockdown.Building_SealableMultiTileDoor</thingClass>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>/Defs/ThingDef[defName="SecurityDoor"]/comps</xpath>
		<value>
			<li Class="BattIePatch_Lockdown.CompProperties_Sealable"/>
		</value>
	</Operation>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Anomaly for Gravship</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>

				<li Class="PatchOperationReplace">
					<xpath>/Defs/ThingDef[defName="ShipSecurityDoor"]/thingClass</xpath>
					<value>
						<thingClass>BattIePatch_Lockdown.Building_SealableMultiTileDoor</thingClass>
					</value>
				</li>

				<li Class="PatchOperationAdd">
					<xpath>/Defs/ThingDef[defName="ShipSecurityDoor"]/comps</xpath>
					<value>
						<li Class="BattIePatch_Lockdown.CompProperties_Sealable"/>
					</value>
				</li>

			</operations>
		</match>
	</Operation>
	
</Patch>